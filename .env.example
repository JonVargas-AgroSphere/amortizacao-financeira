# ============================================
# Configurações de Produção - Amortização Financeira
# Copie este arquivo para .env e preencha os valores
# ============================================

# Porta do servidor (opcional, padrão 3000)
PORT=3000

# Google Analytics 4 (Measurement ID)
# Formato: G-XXXXXXXXXX
GA4_ID=

# Google AdSense (Client ID)
# Formato: ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_CLIENT=

# Número do WhatsApp do corretor/assessor
# Formato: 5511999999999 (apenas números, com DDI e DDD)
WHATSAPP_NUMBER=

# Domínio do site (sem https://)
SITE_DOMAIN=amortizacao-financeira.onrender.com

# Token de administrador para acessar a API de leads
# Gere um token seguro com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=
